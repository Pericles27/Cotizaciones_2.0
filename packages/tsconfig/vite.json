{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Vite + React",
  "extends": "./react.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "types": ["vite/client"]
  }
}
