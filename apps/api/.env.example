PORT=3001
NODE_ENV=development

# Credenciales de Invertir Online (IOL).
# Si no las completás, la API arranca igual pero /bonos y /acciones devuelven 503.
# Aceptamos los nombres nuevos o los del proyecto legacy — usá el que prefieras.
IOL_USERNAME=
IOL_PASSWORD=
# REACT_APP_API_MAIL=  # alternativa legacy a IOL_USERNAME
# REACT_APP_API_PASS=  # alternativa legacy a IOL_PASSWORD

# Cache TTL (segundos) — cuánto tiempo guardamos en memoria cada respuesta de IOL.
CACHE_TTL_SECONDS=30

# Origen permitido por CORS (separar por coma para múltiples).
# En producción ponelo al dominio del frontend, ej:
#   CORS_ORIGIN=https://cotizaciones.netlify.app
# Para incluir también previews de Netlify:
#   CORS_ORIGIN=https://cotizaciones.netlify.app,https://deploy-preview-1--cotizaciones.netlify.app
CORS_ORIGIN=http://localhost:5173
